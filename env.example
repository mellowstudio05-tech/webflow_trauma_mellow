AUTO_PUBLISH=false

# --- Optional: Firebase Firestore ---
# Entweder JSON als eine Zeile (Vercel):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Oder zuverlässiger auf Vercel: komplette JSON-Datei als Base64 (ein Zeile, siehe FIRESTORE_SETUP.md):
# FIREBASE_SERVICE_ACCOUNT_BASE64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50Ii...
# Oder lokal: Pfad zur heruntergeladenen Datei (z.B. mellowedit-d9c74-firebase-adminsdk-....json)
# FIREBASE_SERVICE_ACCOUNT_PATH=/pfad/zu/deinem-projekt-firebase-adminsdk-xxxxx.json
# Firestore-Collection (Standard im Code: cms)
# FIRESTORE_COLLECTION=cms

